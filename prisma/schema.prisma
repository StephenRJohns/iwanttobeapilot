datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String?   @unique
  emailVerified          DateTime?
  image                  String?
  hashedPassword         String?
  tier                   String    @default("free")
  betaExpiresAt          DateTime?
  role                   String    @default("user")
  status                 String    @default("active")
  mustChangePassword     Boolean   @default(false)
  sessionVersion         Int       @default(0)
  promoCodeId            String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  pilotGoal              String?
  zipCode                String?
  settings               String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  termsAcceptances     TermsAcceptance[]
  progress             UserProgress[]
  ratings              Rating[]
  stories              Story[]
  discussions          DiscussionPost[]
  discussionReplies    DiscussionReply[]
  testBankAttempts     TestBankAttempt[]
  testBankWrongAnswers TestBankWrongAnswer[]
  distributingCodes    PromoCode[]          @relation("PromoCodeDistributor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PromoCode {
  id               String    @id @default(cuid())
  code             String    @unique
  blockName        String?
  assignedToUserId String?
  maxUses          Int       @default(1)
  uses             Int       @default(0)
  revoked          Boolean   @default(false)
  discountPct      Int       @default(100)
  durationMonths   Int?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())

  assignedTo User? @relation("PromoCodeDistributor", fields: [assignedToUserId], references: [id], onDelete: SetNull)
}

model TermsAcceptance {
  id           String   @id @default(cuid())
  userId       String
  termsVersion String
  ipAddress    String?
  userAgent    String?
  acceptedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model SiteSettings {
  id                 String   @id @default("singleton")
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  bannerEnabled      Boolean  @default(false)
  bannerMessage      String?
  bannerColor        String   @default("blue")
  updatedAt          DateTime @updatedAt
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  milestone   String
  status      String    @default("pending")
  completedAt DateTime?
  notes       String?
  nextSteps   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
}

model FlightSchool {
  id        String   @id @default(cuid())
  name      String
  address   String
  city      String
  state     String
  zipCode   String
  phone     String?
  email     String?
  website   String?
  lat       Float?
  lng       Float?
  ratings   Rating[]
  createdAt DateTime @default(now())

  @@index([zipCode])
}

model DPERecord {
  id               String   @id @default(cuid())
  name             String
  designeeNumber   String?
  region           String?
  district         String?
  city             String?
  state            String?
  zipCode          String?
  certificateTypes String
  phone            String?
  email            String?
  lat              Float?
  lng              Float?
  ratings          Rating[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([zipCode])
  @@index([state])
}

model Rating {
  id         String        @id @default(cuid())
  userId     String
  targetType String
  schoolId   String?
  dpeId      String?
  score      Int
  title      String?
  body       String
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  school     FlightSchool? @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  dpe        DPERecord?    @relation(fields: [dpeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([schoolId])
  @@index([dpeId])
}

model Story {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  pilotLevels String
  totalMonths Int?
  totalCost   Int?
  salaryRange String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DiscussionCategory {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  icon        String?
  order       Int              @default(0)
  posts       DiscussionPost[]
}

model DiscussionPost {
  id         String             @id @default(cuid())
  userId     String
  categoryId String
  title      String
  body       String
  isPinned   Boolean            @default(false)
  isLocked   Boolean            @default(false)
  viewCount  Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   DiscussionCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  replies    DiscussionReply[]

  @@index([userId])
  @@index([categoryId])
}

model DiscussionReply {
  id        String         @id @default(cuid())
  userId    String
  postId    String
  body      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}

model PassRateCache {
  id          String   @id @default("singleton")
  data        Json
  lastUpdated DateTime
  updatedAt   DateTime @updatedAt
}

model TestBankAttempt {
  id        String   @id @default(cuid())
  userId    String
  testBank  String
  score     Int
  total     Int
  passed    Boolean
  answers   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, testBank])
}

model TestBankWrongAnswer {
  id         String   @id @default(cuid())
  userId     String
  testBank   String
  questionId String
  wrongCount Int      @default(1)
  lastSeenAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, testBank, questionId])
  @@index([userId])
  @@index([userId, testBank])
}
